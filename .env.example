# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001
NODE_ENV=development

# ─── Database (Neon PostgreSQL Free Tier) ────────────────────────────────────
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/alumniverse?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/alumniverse"

# ─── Authentication ───────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=your-super-secret-access-key-at-least-32-chars-long
JWT_REFRESH_SECRET=your-super-secret-refresh-key-at-least-32-chars-long
BCRYPT_ROUNDS=12
OTP_EXPIRY_MINUTES=10

# ─── Email (Resend Free: 3000 emails/month) ───────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_DOMAIN=alumniverse.app
EMAIL_FROM=noreply@alumniverse.app

# ─── Gmail SMTP Fallback ──────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-gmail-app-password

# ─── Cloudinary (Free Tier) ───────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name

# ─── Jitsi Meet (FREE - no key needed) ────────────────────────────────────────
NEXT_PUBLIC_JITSI_DOMAIN=meet.jit.si

# ─── Developer Access (never expose publicly) ─────────────────────────────────
DEVELOPER_ACCESS_KEY=your-developer-secret-key
DEVELOPER_EMAIL=developer@alumniverse.app
